# env.example — Environment configuration for existing infrastructure
#
# Usage:
#   1. Copy this file to .env
#   2. Replace <PLACEHOLDER> values with your actual resource IDs
#   3. Run: source .env && make deploy-existing
#
# Note: .env is in .gitignore (contains account-specific information)

# -------------------------------------------------------------------
# AWS Region & Account
# -------------------------------------------------------------------
export AWS_REGION=ap-northeast-1

# -------------------------------------------------------------------
# Project Settings
# -------------------------------------------------------------------
export PROJECT_NAME=fsxn-cyber-resilience
export ENVIRONMENT=dev

# -------------------------------------------------------------------
# Existing VPC & Network (set USE_EXISTING_VPC=true to use these)
# -------------------------------------------------------------------
export USE_EXISTING_VPC=true
export EXISTING_VPC_ID=<your-vpc-id>
export EXISTING_SUBNET_FSX_1=<subnet-id-az1-for-fsx>
export EXISTING_SUBNET_FSX_2=<subnet-id-az2-for-fsx>
export EXISTING_SUBNET_COMPUTE_1=<subnet-id-az1-for-lambda>
export EXISTING_SUBNET_COMPUTE_2=<subnet-id-az2-for-lambda>
export EXISTING_SG_FSX=<sg-id-for-fsx-eni>
export EXISTING_SG_LAMBDA=<sg-id-for-lambda>

# -------------------------------------------------------------------
# Existing FSx for ONTAP (set USE_EXISTING_FSX=true to use these)
# -------------------------------------------------------------------
export USE_EXISTING_FSX=true
export EXISTING_FS_ID=<fs-id>
export EXISTING_MANAGEMENT_ENDPOINT=<management.fs-xxxx.fsx.ap-northeast-1.amazonaws.com>
export EXISTING_SVM_ID=<svm-id>
export EXISTING_VOLUME_ID=<fsvol-id>

# -------------------------------------------------------------------
# Active Directory (optional — for SMB/CIFS access)
# -------------------------------------------------------------------
export EXISTING_AD_ID=<directory-id-or-empty>

# -------------------------------------------------------------------
# FSx Admin Credentials (stored in Secrets Manager)
# -------------------------------------------------------------------
export FSX_ADMIN_SECRET_NAME=fsxn-cyber-resilience-fsxadmin

# -------------------------------------------------------------------
# Notification
# -------------------------------------------------------------------
export NOTIFICATION_EMAIL=<your-email@example.com>

# -------------------------------------------------------------------
# Discovery Commands (run these to find your resource IDs)
# -------------------------------------------------------------------
# VPC:
#   aws ec2 describe-vpcs --query 'Vpcs[*].[VpcId,Tags[?Key==`Name`].Value|[0]]' --output table
#
# Subnets:
#   aws ec2 describe-subnets --filters "Name=vpc-id,Values=$EXISTING_VPC_ID" \
#     --query 'Subnets[*].[SubnetId,AvailabilityZone,Tags[?Key==`Name`].Value|[0]]' --output table
#
# Security Groups:
#   aws ec2 describe-security-groups --filters "Name=vpc-id,Values=$EXISTING_VPC_ID" \
#     --query 'SecurityGroups[*].[GroupId,GroupName]' --output table
#
# FSx for ONTAP:
#   aws fsx describe-file-systems --query 'FileSystems[*].[FileSystemId,DNSName,OntapConfiguration.DeploymentType]' --output table
#
# SVMs:
#   aws fsx describe-storage-virtual-machines --query 'StorageVirtualMachines[*].[StorageVirtualMachineId,Name]' --output table
#
# Volumes:
#   aws fsx describe-volumes --query 'Volumes[*].[VolumeId,Name,OntapConfiguration.JunctionPath]' --output table
#
# Active Directory:
#   aws ds describe-directories --query 'DirectoryDescriptions[*].[DirectoryId,Name,Type]' --output table
